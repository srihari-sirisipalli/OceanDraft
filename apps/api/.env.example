NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://ocean:ocean@localhost:5432/oceandraft?schema=public
REDIS_URL=redis://localhost:6379

CORS_ALLOWED_ORIGINS=http://localhost:3000

# Session / auth
SESSION_COOKIE_SECRET=change-me-please-very-long-random-string
JWT_SECRET=change-me-too-please-long-random-string
CANDIDATE_SESSION_TTL_SECONDS=900
ADMIN_SESSION_IDLE_MINUTES=30

# Cookies: only set true when the server is actually behind HTTPS.
# Single-laptop http://localhost deployments must keep this false.
COOKIE_SECURE=false

# OTP
SMS_PROVIDER=dev
OTP_DEV_MODE=true
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_RESENDS_PER_15M=3
OTP_MAX_VERIFY_ATTEMPTS=5

# Real providers
MSG91_AUTH_KEY=
MSG91_SENDER_ID=OCNDFT
MSG91_TEMPLATE_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=oceandraft-media
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniosecret
S3_FORCE_PATH_STYLE=true

# Business
CAPTCHA_ENABLED=false
ATTEMPT_POLICY=SINGLE_LIFETIME
ASSIGNMENT_MODE=RANDOM_ACTIVE
RESULT_REVEAL_CORRECT_ON_FAIL=false

# Seed admin
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@oceandraft.local
SEED_ADMIN_PASSWORD=ChangeMe!123456
