# ------------------------------------------------------------------------------
# OceanDraft — root .env.example
# Copy to .env at repo root and edit as needed. Per-app .env files live in
# apps/api/.env and apps/web/.env.local (both follow the same keys below).
# ------------------------------------------------------------------------------

# Runtime
NODE_ENV=development

# URLs
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
API_PUBLIC_URL=http://localhost:4000

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://ocean:ocean@localhost:5432/oceandraft?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Object storage (MinIO in docker-compose)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=oceandraft-media
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniosecret
S3_FORCE_PATH_STYLE=true

# SMS / OTP
# When OTP_DEV_MODE=true, OTPs are logged to the API console instead of sent.
SMS_PROVIDER=dev
OTP_DEV_MODE=true
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_RESENDS_PER_15M=3
OTP_MAX_VERIFY_ATTEMPTS=5

# Real provider keys (leave blank in dev)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=OCNDFT
MSG91_TEMPLATE_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Candidate / admin session
CANDIDATE_SESSION_TTL_SECONDS=900
ADMIN_SESSION_IDLE_MINUTES=30
SESSION_COOKIE_SECRET=change-me-please-very-long-random-string
JWT_SECRET=change-me-too-please-long-random-string

# Default admin seed
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@oceandraft.local
SEED_ADMIN_PASSWORD=ChangeMe!123456

# Business toggles
CAPTCHA_ENABLED=false
ATTEMPT_POLICY=SINGLE_LIFETIME
ASSIGNMENT_MODE=RANDOM_ACTIVE
RESULT_REVEAL_CORRECT_ON_FAIL=false

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
